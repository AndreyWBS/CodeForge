{
  "requiredConfig": {
    "database": "Configurações de conexão MySQL usadas pelo plugin db-mapper (host, port, user, password, database)"
  },
  "globalContext": {
    "entityName": "User",
    "tableName": "users",
    "hasCreate": true
  },
  "plugins": [
    {
      "name": "db-schema.js"
    },
    {
      "name": "api-resources.js"
    }
  ],
  "files": [
    {
      "templatePath": "./arquivos/config/env.hbs",
      "outputPath": "../dist/src/config/env.js"
    },
    {
      "templatePath": "./arquivos/config/env-example.hbs",
      "outputPath": "../dist/.env.example"
    },
    {
      "templatePath": "./arquivos/infra/database/connection.hbs",
      "outputPath": "../dist/src/infra/database/connection.js"
    },
    {
      "templatePath": "./arquivos/models/base.model.hbs",
      "outputPath": "../dist/src/models/base.model.js"
    },
    {
      "templatePath": "./arquivos/services/base.service.hbs",
      "outputPath": "../dist/src/services/base.service.js"
    },
    {
      "templatePath": "./arquivos/models/resource.model.hbs",
      "outputPath": "../dist/src/models/{{toCamelCase resource.name}}.model.js",
      "forEach": "apiResources",
      "itemAlias": "resource"
    },
    {
      "templatePath": "./arquivos/services/resource.service.hbs",
      "outputPath": "../dist/src/services/{{toCamelCase resource.name}}.service.js",
      "forEach": "apiResources",
      "itemAlias": "resource"
    },
    {
      "templatePath": "./arquivos/controllers/resource.controller.hbs",
      "outputPath": "../dist/src/controllers/{{toCamelCase resource.name}}.controller.js",
      "forEach": "apiResources",
      "itemAlias": "resource"
    },
    {
      "templatePath": "./arquivos/routers/resource.router.hbs",
      "outputPath": "../dist/src/routers/{{toCamelCase resource.name}}.router.js",
      "forEach": "apiResources",
      "itemAlias": "resource"
    },
    {
      "templatePath": "./arquivos/apps/app.solid.hbs",
      "outputPath": "../dist/src/app.solid.js"
    }
  ]
}
