app.get('/{{this}}', (req, res) => {
  res.json({ table: '{{this}}', action: 'list' });
});

app.get('/{{this}}/:id', (req, res) => {
  res.json({ table: '{{this}}', action: 'get', id: req.params.id });
});

app.post('/{{this}}', (req, res) => {
  res.status(201).json({ table: '{{this}}', action: 'create', data: req.body });
});

app.put('/{{this}}/:id', (req, res) => {
  res.json({ table: '{{this}}', action: 'update', id: req.params.id, data: req.body });
});

app.delete('/{{this}}/:id', (req, res) => {
  res.status(204).send();
});
