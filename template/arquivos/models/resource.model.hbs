import { BaseModel } from './base.model.js';

export class {{toPascalCase resource.name}}Model extends BaseModel {
  constructor() {
    super('{{resource.name}}', '{{resource.primaryKey}}', [
{{#each resource.columns}}
      '{{this}}',
{{/each}}
    ]);
  }

{{#each resource.customRoutes}}
  async {{handlerName}}(params, query, body) {
    return this.executeCustomRoute('{{handlerName}}', params, query, body);
  }

{{/each}}
}
