import { Router } from 'express';
import { {{toPascalCase resource.name}}Service } from '../services/{{toCamelCase resource.name}}.service.js';
import { {{toPascalCase resource.name}}Controller } from '../controllers/{{toCamelCase resource.name}}.controller.js';

export function create{{toPascalCase resource.name}}Router() {
  const router = Router();
  const service = new {{toPascalCase resource.name}}Service();
  const controller = new {{toPascalCase resource.name}}Controller(service);

{{#if resource.crud.list}}
  router.get('/', (req, res, next) => controller.list(req, res, next));
{{/if}}
{{#if resource.crud.getById}}
  router.get('/:id', (req, res, next) => controller.getById(req, res, next));
{{/if}}
{{#if resource.crud.create}}
  router.post('/', (req, res, next) => controller.create(req, res, next));
{{/if}}
{{#if resource.crud.update}}
  router.put('/:id', (req, res, next) => controller.update(req, res, next));
{{/if}}
{{#if resource.crud.remove}}
  router.delete('/:id', (req, res, next) => controller.remove(req, res, next));
{{/if}}

{{#each resource.customRoutes}}
{{> router-custom-route}}
{{/each}}

  return router;
}
