{
  "requiredConfig": {
    "database": "Configurações de conexão MySQL usadas pelo plugin db-mapper (host, port, user, password, database)"
  },
  "globalContext": {
    "entityName": "User",
    "tableName": "users",
    "hasCreate": true,
    "metodos": [
      {
        "name": "findAll",
        "description": "Busca todos os Users",
        "params": []
      },
      {
        "name": "findById",
        "description": "Busca User por ID",
        "params": ["id"]
      },
      {
        "name": "create",
        "description": "Cria um novo User",
        "params": ["data"]
      },
      {
        "name": "delete",
        "description": "Remove um User pelo ID",
        "params": ["id"]
      }
    ]
  },
  "files": [
    {
      "templatePath": "./arquivos/controller.hbs",
      "outputPath": "../dist/src/UserController.js"
    },
    {
      "templatePath": "./arquivos/app.hbs",
      "outputPath": "../dist/App.js"
    },
    {
      "templatePath": "./arquivos/tabelas.hbs",
      "outputPath": "../dist/tabelas.js"
    }
  ]
}
